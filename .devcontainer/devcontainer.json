{
  "name": "Desktop Browser",
  "build": { "dockerfile": "Dockerfile" },
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "password": "mypassword",
      "webPort": "6080"
    }
  },
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "Desktop",
      "onAutoForward": "openBrowser"
    }
  },
  "remoteUser": "vscode"
}
